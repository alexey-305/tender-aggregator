# Postgres
POSTGRES_USER=tender
POSTGRES_PASSWORD=tender
POSTGRES_DB=tender_aggregator
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://tender:tender@postgres:5432/tender_aggregator

# OpenSearch
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX_TENDERS=tenders

# EIS (zakupki.gov.ru) — с 01.01.2025 доступ только через SOAP-сервис отдачи информации,
# токен из личного кабинета ЕИС (требует действующую ЭЦП): pmd.zakupki.gov.ru/pmd/lk/token
EIS_TOKEN=
EIS_SOAP_URL=https://int44.zakupki.gov.ru/eis-integration/services/getDocsIP

# Anthropic (для будущего трека Б — ИИ-ассистент)
ANTHROPIC_API_KEY=

APP_ENV=local
LOG_LEVEL=INFO
